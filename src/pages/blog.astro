---
import { getCollection } from 'astro:content';
import Breadcrumb from '../components/Breadcrumb/Breadcrumb.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  blogCategoryPath,
  uniqueSortedCategoryNames,
  withBaseUrl
} from '../lib/blog';

const baseUrl = import.meta.env.BASE_URL;
const siteName = 'Ján Korkoš';

const blogEntries = await getCollection('blog');
const categoryNames = uniqueSortedCategoryNames(blogEntries);

const breadcrumbItems = [
  { label: 'Home', href: withBaseUrl(baseUrl, '/') },
  { label: 'Blog' }
];
---

<BaseLayout title={`Blog | ${siteName}`}>
  <Breadcrumb items={breadcrumbItems} />
  <h2>Blog</h2>
  <p>Browse by category.</p>
  {
    categoryNames.length === 0 ? (
      <p>No categories yet.</p>
    ) : (
      <ul>
        {categoryNames.map((categoryName) => (
          <li>
            <a href={withBaseUrl(baseUrl, blogCategoryPath(categoryName))}>{categoryName}</a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
